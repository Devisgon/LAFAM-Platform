{
  "name": "@lafam/web",
  "version": "0.1.0",
  "private": true,
  "description": "LAFAM Next.js admin dashboard frontend.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "check": "pnpm run lint && pnpm run typecheck",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{js,mjs,ts,json,md}\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@supabase/supabase-js": "^2.107.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "babel-plugin-react-compiler": "1.0.0"
  }
