# ---------------------------------------------------------------------------
# LAFAM API Environment Example
# Copy this file to apps/api/.env for local backend development.
# Never commit real .env files.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Allowed values: development, test, staging, production
NODE_ENV=development

# Local API port
PORT=4000

# Global backend route prefix.
# Example: api means routes are served under /api.
API_GLOBAL_PREFIX=api

# Allowed frontend browser origin.
# Use comma-separated origins only when needed.
# Example: http://localhost:3000,https://admin.lafam.com
WEB_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Required for Auth and database access.
# Get these from Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-only key. Never expose this to frontend code.
# Use the service-role/server secret key from Supabase.
SUPABASE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
# Optional until monitoring is enabled.
SENTRY_DSN=

# Required by current API config validation.
SENTRY_ENVIRONMENT=development

# Must be between 0 and 1.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Brevo
# ---------------------------------------------------------------------------
# Optional until transactional emails are enabled.
# If BREVO_API_KEY is set, BREVO_SENDER_EMAIL must also be set.
# If BREVO_SENDER_EMAIL is set, BREVO_API_KEY must also be set.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Required sender display name.
BREVO_SENDER_NAME=LAFAM

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# JWT clock tolerance in seconds.
JWT_CLOCK_TOLERANCE_SECONDS=30

# Request body size limit.
# Valid examples: 100kb, 1mb, 1048576
REQUEST_BODY_LIMIT=1mb

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Server-only pepper used when hashing access tokens, refresh tokens, and reset tokens.
# Use a long random value in real environments. Never expose this to frontend code.
AUTH_ACCESS_TOKEN_HASH_PEPPER=

# Password reset token validity window after reset OTP verification.
AUTH_RESET_TOKEN_TTL_MINUTES=15

# Maximum failed reset OTP attempts before blocking the reset challenge.
AUTH_MAX_RESET_OTP_ATTEMPTS=5

# Supabase Storage bucket used for user avatars.
AUTH_AVATAR_BUCKET=avatars

# Maximum avatar upload size in bytes. Default: 2 MB.
AUTH_AVATAR_MAX_SIZE_BYTES=2097152

# Signed avatar URL validity in seconds.
AUTH_AVATAR_SIGNED_URL_TTL_SECONDS=3600

# Guest session validity window.
AUTH_GUEST_SESSION_TTL_HOURS=24

# Guest session creation rate limit per IP per hour.
AUTH_GUEST_MAX_SESSIONS_PER_IP_PER_HOUR=20

# Require captcha token for guest session creation.
AUTH_GUEST_REQUIRE_CAPTCHA=false

# Enable request-time cleanup/enforcement for expired guest sessions.
AUTH_GUEST_CLEANUP_ENABLED=true

# ---------------------------------------------------------------------------
# Payments
# ---------------------------------------------------------------------------
# Local development should use mock so KNET credentials are not required.
# Allowed values: mock, knet, tap, myfatoorah, checkout
PAYMENT_PROVIDER=mock

# Allowed values: sandbox, production
# Use sandbox for local/staging development and production only with real provider credentials.
PAYMENT_MODE=sandbox

# Current Payment Module supports KWD because KNET payments are KWD-only.
PAYMENT_DEFAULT_CURRENCY=KWD

# Public backend base URL used to build payment callback and webhook URLs.
# Local mock development can use localhost.
# Real provider sandbox/production webhooks usually require a public HTTPS URL.
PAYMENT_PUBLIC_BASE_URL=http://localhost:4000

# Frontend page where the backend redirects the customer after successful payment verification.
PAYMENT_FRONTEND_SUCCESS_URL=http://localhost:3000/payment/success

# Frontend page where the backend redirects the customer after failed, cancelled, or expired payment.
PAYMENT_FRONTEND_FAILURE_URL=http://localhost:3000/payment/failed

# ---------------------------------------------------------------------------
# KNET / Hosted Payment Provider
# ---------------------------------------------------------------------------
# Optional when PAYMENT_PROVIDER=mock.
# Required when PAYMENT_PROVIDER is knet, tap, myfatoorah, or checkout.
# Never expose these values to frontend code.
KNET_MERCHANT_ID=
KNET_SECRET_KEY=
KNET_WEBHOOK_SECRET=

# Production provider API base URL.
# Required when PAYMENT_PROVIDER is not mock and PAYMENT_MODE=production.
KNET_API_BASE_URL=

# Sandbox provider API base URL.
# Required when PAYMENT_PROVIDER is not mock and PAYMENT_MODE=sandbox.
KNET_SANDBOX_API_BASE_URL=

# ---------------------------------------------------------------------------
# Pilates
# ---------------------------------------------------------------------------
# Pilates class image storage
PILATES_CLASS_IMAGE_BUCKET=pilates-class-images